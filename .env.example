# Cho Works environment template.
# Copy this file to .env, then edit values for your machine:
#   cp .env.example .env

# Optional. If omitted, Cho Works uses ~/.cho-works/cho_works.sqlite3.
# Keep this file on a persistent disk when deploying.
CHO_WORKS_DB_PATH=~/.cho-works/cho_works.sqlite3

# Advanced. To use an env file from another location, set this in your shell
# before running Cho Works. It cannot relocate this file after this file is read.
# CHO_WORKS_ENV_FILE=/path/to/.env

# Optional. Leave blank to use the local deterministic summarizer.
# To enable LLM summaries, install with the llm extra and set your key:
#   uv sync --extra llm
OPENAI_API_KEY=
CHO_WORKS_OPENAI_MODEL=gpt-4o-mini
